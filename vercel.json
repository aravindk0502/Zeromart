{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "^/api(?:/.*)?$",
      "dest": "/api/index"
    },
    {
      "src": "^/product/([^/]+)$",
      "dest": "/api/index"
    },
    {
      "src": "^/product-image/([^/]+)$",
      "dest": "/api/index"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    }
  ]
}
