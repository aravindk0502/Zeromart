{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]

  ,"redirects": [
    {
      "source": "/(.*)",
      "has": [ { "type": "host", "value": "drizn.com" } ],
      "destination": "https://www.drizn.com/$1",
      "statusCode": 308
    }
  ]
}
