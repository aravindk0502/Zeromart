# ── Copy to .env.local for local dev ──────────────────────────────────────────
# On Railway: set these in Project → Variables (no file needed)

# Supabase — supabase.com → Project → Settings → API
REACT_APP_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJ...

# Service key (server-side only, never exposed to browser)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# MSG91 — msg91.com → API → OTP
# Create a template with ##OTP## placeholder + DLT registration
MSG91_AUTH_KEY=your_msg91_authkey
MSG91_TEMPLATE_ID=your_template_id

# Razorpay — dashboard.razorpay.com → Settings → API Keys
REACT_APP_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Railway sets PORT automatically — do not set this yourself
# PORT=3001
