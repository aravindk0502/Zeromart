# ── Vercel frontend variables ─────────────────────────────────────────────────

# Public Railway API URL. Do not add a trailing slash.
VITE_API_URL=https://api.drizn.com

# Supabase public frontend values. These are safe for Vercel when the anon key is RLS-scoped.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Browser key: restrict it to the production Vercel domain and localhost.
# Restrict APIs to Maps JavaScript API, Places API, and Geocoding API.
VITE_GOOGLE_MAPS_API_KEY=YOUR_RESTRICTED_BROWSER_KEY

# Optional same-origin or secured backend proxy for Google Address Validation.
VITE_GOOGLE_ADDRESS_VALIDATION_ENDPOINT=

# ── Railway backend variables ─────────────────────────────────────────────────

# PostgreSQL — auto-set by Railway when you add the Postgres plugin
DATABASE_URL=postgresql://user:pass@host:5432/railway
POSTGRES_PASSWORD=your_postgres_password

# Supabase server values. Keep these only in Railway/backend env, never in Vercel client env.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=Drizn

# JWT secret — any long random string (keep it secret)
JWT_SECRET=change-this-to-a-long-random-string

# Comma-separated frontend origins allowed to call the Railway API.
CORS_ORIGIN=https://your-zeromart.vercel.app,http://localhost:3002

# MSG91 — msg91.com → API → OTP
MSG91_AUTH_KEY=your_msg91_authkey
MSG91_TEMPLATE_ID=your_template_id

# Razorpay — dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Railway sets PORT automatically — do not set this yourself
